# =============================================================
#  PLANTILLA DE VARIABLES DE ENTORNO (sin valores reales)
#  Copia este archivo como ".env.local" y rellena tus valores.
#  El archivo .env.local NUNCA se sube a git (está en .gitignore).
# =============================================================

# Mercado Pago: Access Token (de PRUEBA empieza con TEST-, el de
# PRODUCCIÓN con APP_USR-). Sácalo de tu panel de Mercado Pago.
MERCADOPAGO_ACCESS_TOKEN=

# URL pública del sitio. En local: http://localhost:3000
# En producción: tu dominio, ej https://konamoda.pe
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contraseña del panel /admin. Usa una fuerte y única (12+ caracteres).
ADMIN_PASSWORD=

# Clave interna para firmar la sesión del panel. Genera una al azar, ej:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=
